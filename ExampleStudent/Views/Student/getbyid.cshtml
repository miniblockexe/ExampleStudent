@model ExampleStudent.Models.Domain.Student

@{
    ViewData["Title"] = "Chi tiết sinh viên";
}

<h1 class="text-center">THÔNG TIN CHI TIẾT SINH VIÊN</h1>

<div class="container mt-4">
    <div class="card shadow">
        <div class="row g-0">
            <div class="col-md-4 text-center p-4">
                <img src="@Model.ImgUrl" class="img-fluid rounded shadow-sm"
                     alt="Ảnh của @Model.Name" style="max-height: 300px;">
            </div>

            <div class="col-md-8">
                <div class="card-body">
                    <h3 class="card-title text-primary">@Model.Name</h3>
                    <hr>

                    <p class="card-text"><strong>Mã số sinh viên (MSSV):</strong> @Model.Mssv</p>

                    <p class="card-text">
                        <strong>Ngày sinh:</strong> @Model.Birth.ToString("dd/MM/yyyy")
                    </p>

                    <p class="card-text">
                        <strong>Giới tính:</strong> @(Model.Gender ? "Nam" : "Nữ")
                    </p>

                    <div class="mt-3">
                        <strong>Mô tả bản thân:</strong>
                        <p class="text-muted italic">
                            @(string.IsNullOrWhiteSpace(Model.Description)
                                ? "Chưa có thông tin mô tả."
                                : Model.Description)
                        </p>
                    </div>

                    <div class="mt-4">
                        <a href="~/Student/Edit/@Model.Id" class="btn btn-warning">Chỉnh sửa</a>
                        <a href="~/Student/getall" class="btn btn-secondary">Quay lại danh sách</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>